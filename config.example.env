# OSU SLURM Dashboard Configuration
# Copy this file to config.env and fill in your details:
#   cp config.example.env config.env

# ── Required ──────────────────────────────────────────────────────
# Your OSU netID (the username you SSH with).
SLURM_USER=

# ── Optional (sensible defaults) ──────────────────────────────────
# Your SLURM account/group (shown in the header).
SLURM_GROUP=eecs

# Path to the SSH private key used for access.engr.oregonstate.edu.
SSH_IDENTITY=~/.ssh/id_ed25519

# Local port the dashboard binds to.
DASHBOARD_PORT=8899

# ── Cluster-specific (baked in for the OSU HPC) ──────────────────
# Gateway host, partitions (dgxh/dgx2/dgxs/gpu/ampere/eecs/share),
# billing rates, and GPU-type labels are hardcoded to match the OSU
# College of Engineering HPC cluster. If you are on the same cluster,
# you do not need to change anything below.
